# ──────────────────────────────────────────────────────────────
# Revenant — Environment Variables
# Copy this to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── Tavus (Video Avatar) ─────────────────────────────────────
TAVUS_API_KEY=
TAVUS_REPLICA_ID=rf4e9d9790f0
TAVUS_PERSONA_ID=                  # Leave blank to auto-create on first run

# ── Anthropic (Claude — the avatar's brain) ──────────────────
ANTHROPIC_API_KEY=

# ── Moorcheh AI (Vector Memory) ──────────────────────────────
MOORCHEH_API_KEY=
MOORCHEH_ENDPOINT=https://api.moorcheh.ai/v1

# ── OpenAI (fallback chat proxy) ─────────────────────────────
OPENAI_API_KEY=

# ── Unified.to (Slack, GitHub, Jira, Gmail integrations) ─────
UNIFIED_API_KEY=
UNIFIED_WORKSPACE_ID=
UNIFIED_WEBHOOK_SECRET=
UNIFIED_BASE_URL=https://api.unified.to
UNIFIED_ENV=Production

# ── Browser Use (NanoClaw autonomous browsing) ───────────────
BROWSER_USE_API_KEY=

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://symbiote:symbiote@localhost:5432/symbiote

# ── Redis (Event buffer) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── FastAPI Backend ──────────────────────────────────────────
FASTAPI_BASE_URL=http://127.0.0.1:8000
FASTAPI_PORT=8000
FASTAPI_DEBUG=false

# ── Public URL (OAuth callbacks & redirects) ─────────────────
# Local: http://localhost:3000 | Prod: https://yourdomain.com
PUBLIC_APP_URL=http://localhost:3000
# CORS — JSON array of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Next.js App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Used for Tavus custom LLM callback
