# ── Omniate v0 Environment Variables ──────────────────────
# Copy to .env and fill in real values.

# AI / LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Memory (Moorcheh - Tier 2/3, future)
MOORCHEH_API_KEY=
MOORCHEH_ENDPOINT=https://api.moorcheh.ai/v1

# Composio (Slack/Jira/GitHub integration webhooks)
COMPOSIO_API_KEY=
COMPOSIO_WEBHOOK_SECRET=

# Database
DATABASE_URL=postgresql+asyncpg://omniate:omniate@localhost:5432/omniate
REDIS_URL=redis://localhost:6379/0

# Auth (change JWT_SECRET_KEY in production!)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Backend
FASTAPI_BASE_URL=http://127.0.0.1:8000
FASTAPI_PORT=8000
FASTAPI_DEBUG=true

# Frontend / CORS
PUBLIC_APP_URL=http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
NEXT_PUBLIC_APP_URL=http://localhost:3000
